pipeline {

    agent any

    environment {
        APP_NAME = "devops-nbd"
        IMAGE = "devops-nbd:v1"
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                checkout scm
            }
        }

        stage('Workspace') {
            steps {
                sh '''
                pwd
                ls -la
                '''
            }
        }

        stage('Verify Dockerfile') {
            steps {
                sh '''
                echo "===== Dockerfile ====="
                ls app
                cat app/Dockerfile
                '''
            }
        }

        stage('Git Information') {
            steps {
                sh '''
                git --version
                git branch
                git log --oneline -5
                '''
            }
        }

        stage('Helm Validation') {
            steps {
                sh '''
                helm version
                helm lint helm/devops-nbd
                '''
            }
        }

        stage('Manifest Preview') {
            steps {
                sh '''
                helm template devops helm/devops-nbd | head -50
                '''
            }
        }

        stage('Kubernetes Validation') {
            steps {
                sh '''
                kubectl version --client

                for f in kubernetes/*.yaml
                do
                  echo "Checking $f"
                  kubectl apply --dry-run=client -f $f
                done
                '''
            }
        }

        stage('Pipeline Complete') {
            steps {
                echo 'Enterprise CI Validation Successful'
            }
        }
    }

    post {
        success {
            echo 'Pipeline SUCCESS'
        }

        failure {
            echo 'Pipeline FAILED'
        }

        always {
            deleteDir()
        }
    }
}